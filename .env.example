PORT=3001
MONGODB_URI=mongodb://localhost:27017/toysemporium
JWT_SECRET=change-me-in-production-use-openssl-rand
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# Order emails (customer notifications)
MAIL_ENABLED=true
MAIL_FROM="Toys Emporium" <orders@yourdomain.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Without SMTP_* set, emails are printed in the backend console (dev mode).
